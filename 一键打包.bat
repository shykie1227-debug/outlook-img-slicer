@echo off
chcp 65001 >nul
title Outlook 长图助手 V6 - 一键打包
color 0A

echo.
echo ============================================================
echo    Outlook 长图助手 V6 - 一键打包
echo ============================================================
echo.
echo  正在启动打包脚本，请稍候...
echo.

cd /d "%~dp0"

powershell -NoProfile -ExecutionPolicy Bypass -File "%~dp0一键打包.ps1"

if errorlevel 1 (
    echo.
    echo ============================================================
    echo    打包失败！请查看上方错误信息
    echo ============================================================
    echo.
    pause
    exit /b 1
)

echo.
echo ============================================================
echo    打包完成！按任意键退出
echo ============================================================
echo.
pause >nul
